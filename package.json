{
  "name": "farmshare-africa",
  "version": "1.0.0",
  "description": "Fractional farm investment platform on Hedera network",
  "main": "index.js",
  "scripts": {
    "setup:all": "npm run setup:frontend && npm run setup:backend && npm run setup:mobile",
    "setup:frontend": "cd frontend && npm install",
    "setup:backend": "cd backend && npm install",
    "setup:mobile": "cd mobile && npm install",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd mobile && npm start",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "deploy:all": "npm run deploy:frontend && npm run deploy:backend",
    "deploy:frontend": "cd frontend && vercel --prod",
    "deploy:backend": "cd backend && railway up",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test"
  },
  "keywords": ["hedera", "defi", "agriculture", "africa", "web3"],
  "author": "Your Name",
  "license": "MIT",
  "workspaces": ["frontend", "backend", "mobile", "smart-contracts"]
}
